{
  "name": "@wosm/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "wosm": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wosm/config": "workspace:*",
    "@wosm/contracts": "workspace:*",
    "@wosm/observability": "workspace:*",
    "@wosm/observer": "workspace:*",
    "@wosm/protocol": "workspace:*",
    "@wosm/runtime": "workspace:*",
    "@wosm/tmux": "workspace:*",
    "@wosm/worktrunk": "workspace:*"
  }
}
