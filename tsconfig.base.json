{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@wosm/cli": ["apps/cli/src/index.ts"],
      "@wosm/cli/internal": ["apps/cli/src/internal.ts"],
      "@wosm/observer": ["apps/observer/src/index.ts"],
      "@wosm/observer/internal": ["apps/observer/src/internal.ts"],
      "@wosm/tui": ["apps/tui/src/index.ts"],
      "@wosm/client": ["packages/client/src/index.ts"],
      "@wosm/config": ["packages/config/src/index.ts"],
      "@wosm/contracts": ["packages/contracts/src/index.ts"],
      "@wosm/dashboard-core": ["packages/dashboard-core/src/index.ts"],
      "@wosm/dashboard-core/*": ["packages/dashboard-core/src/*"],
      "@wosm/claude": ["integrations/harness/claude/src/index.ts"],
      "@wosm/codex": ["integrations/harness/codex/src/index.ts"],
      "@wosm/cursor": ["integrations/harness/cursor/src/index.ts"],
      "@wosm/github-repository": ["integrations/repository/github/src/index.ts"],
      "@wosm/opencode": ["integrations/harness/opencode/src/index.ts"],
      "@wosm/observability": ["packages/observability/src/index.ts"],
      "@wosm/pi": ["integrations/harness/pi/src/index.ts"],
      "@wosm/provider-hooks": ["packages/provider-hooks/src/index.ts"],
      "@wosm/protocol": ["packages/protocol/src/index.ts"],
      "@wosm/runtime": ["packages/runtime/src/index.ts"],
      "@wosm/scripted-harness": ["integrations/harness/scripted/src/index.ts"],
      "@wosm/testing": ["packages/testing/src/index.ts"],
      "@wosm/tmux": ["integrations/terminal/tmux/src/index.ts"],
      "@wosm/worktrunk": ["integrations/worktree/worktrunk/src/index.ts"]
    }
  }
}
