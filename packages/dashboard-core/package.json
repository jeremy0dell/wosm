{
  "name": "@wosm/dashboard-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./flows/*": {
      "types": "./dist/flows/*.d.ts",
      "import": "./dist/flows/*.js"
    },
    "./selectors/*": {
      "types": "./dist/selectors/*.d.ts",
      "import": "./dist/selectors/*.js"
    },
    "./services/*": {
      "types": "./dist/services/*.d.ts",
      "import": "./dist/services/*.js"
    },
    "./state/*": {
      "types": "./dist/state/*.d.ts",
      "import": "./dist/state/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wosm/client": "workspace:*",
    "@wosm/contracts": "workspace:*",
    "@wosm/runtime": "workspace:*",
    "string-width": "^8.2.1",
    "zustand": "^5.0.14"
  }
}
